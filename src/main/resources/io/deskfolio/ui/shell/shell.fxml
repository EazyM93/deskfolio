<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="io.deskfolio.ui.shell.ShellController"
            styleClass="app-shell">
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" spacing="18" prefWidth="240">
            <padding>
                <Insets top="24" right="16" bottom="24" left="16"/>
            </padding>
            <Label text="DeskFolio" styleClass="app-title"/>
            <VBox fx:id="navigationContainer" styleClass="navigation-list" spacing="6"/>
        </VBox>
    </left>
    <center>
        <VBox styleClass="main-panel" spacing="20">
            <padding>
                <Insets top="28" right="32" bottom="32" left="32"/>
            </padding>
            <HBox styleClass="top-bar" spacing="16">
                <Button fx:id="sidebarToggleButton"
                        text="‹"
                        accessibleText="Hide sidebar"
                        mnemonicParsing="false"
                        onAction="#toggleSidebar"
                        styleClass="icon-button"/>
                <Label fx:id="pageTitle" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <StackPane fx:id="contentRegion" styleClass="content-region" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
